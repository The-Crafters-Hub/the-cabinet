        "googleAnalyticsOAuth2Api": {
          "id": "CREATE_THIS_IN_UI",
          "name": "GA4 Marketing Account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const results = [];\nconst logDate = item.date.replace(/(\\d{4})(\\d{2})(\\d{2})/, '$1-$2-$3');\n\nif (item.metricValues && item.metricValues.length >= 2) {\n  results.push({\n    log_date: logDate,\n    platform: 'ga4',\n    metric_name: 'activeUsers',\n    metric_value: parseFloat(item.metricValues[0].value)\n  });\n  results.push({\n    log_date: logDate,\n    platform: 'ga4',\n    metric_name: 'sessions',\n    metric_value: parseFloat(item.metricValues[1].value)\n  });\n}\n\nreturn results;"
      },
      "id": "1d4a5f6e-7b8c-4a9d-b2e1-c3f4a5b6c7d8",
