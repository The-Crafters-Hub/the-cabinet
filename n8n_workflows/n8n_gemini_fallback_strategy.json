        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ contents: [{ parts: [{ text: $('Resilient Webhook').first().json.body.prompt }] }], generationConfig: { maxOutputTokens: 256, temperature: 0.5 } }) }}",
        "options": { "timeout": 15000 }
      },
      "id": "fallback-lite",
      "name": "Fallback: Gemini 3.1 Flash-Lite",
