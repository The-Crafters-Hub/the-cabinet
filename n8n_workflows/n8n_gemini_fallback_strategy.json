        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ contents: [{ parts: [{ text: $json.body.prompt }] }], generationConfig: { maxOutputTokens: $json.body.max_tokens || 512, temperature: $json.body.temperature || 0.7 } }) }}",
        "options": { "timeout": 15000 }
      },
      "id": "primary-gemini",
      "name": "Primary: Gemini 3.5 Flash",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 200],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.candidates ? true : false }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ]
        }
      },
      "id": "check-primary",
      "name": "Primary OK?",
      "type": "n8n-nodes-base.if",
