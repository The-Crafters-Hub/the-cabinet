# ════════════════════════════════════════════════
# THE CABINET — Environment Variables Template
# Copy this to .env and fill in your values.
# NEVER commit the real .env file to Git.
# ════════════════════════════════════════════════

# PostgreSQL
POSTGRES_USER=crafter_admin
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=thecraftershub
POSTGRES_PORT=5432
TZ=Africa/Cairo

# n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_password_here
N8N_ENCRYPTION_KEY=generate_a_random_32char_string
N8N_API_KEY=your_n8n_api_key_here
N8N_HOST=localhost
N8N_PORT=5678
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Gemini API (Google AI Studio - free tier)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Cabinet API
CABINET_API_KEY=generate_a_random_secret_here
ENVIRONMENT=production

# Meta / WhatsApp Business API
META_VERIFY_TOKEN=your_webhook_verify_token
META_APP_SECRET=your_meta_app_secret
META_PHONE_NUMBER_ID=your_phone_number_id
META_WABA_ID=your_waba_id

# Cloudflare Tunnel (optional - for webhook exposure)
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_token

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_password_here
